# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Arkham Intelligence API
ARKHAM_SESSION_COOKIE=your_arkham_session_cookie_here
ARKHAM_X_PAYLOAD=your_arkham_x_payload_here
ARKHAM_WEBHOOK_TOKEN=your_arkham_webhook_token_here

# Database Configuration
WALLETS_DB_PATH=wallets.db

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
TELEGRAM_BOT_TOKEN2=your_second_bot_token_here
TELEGRAM_CHAT_ID2=your_second_chat_id_here
COPYTRADE_BOT_TOKEN=your_copytrade_bot_token_here
COPYTRADE_CHAT_ID=your_copytrade_chat_id_here

# Blockchain RPC & API Keys
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_WEBHOOK_SECRET=your_helius_webhook_secret_here
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
QUICKNODE_API_KEY=your_quicknode_api_key_here
JUPITER_API_KEY=your_jupiter_api_key_here
INFURA_API_KEY=your_infura_api_key_here

# AI API Keys
GEMINI_API_KEY=your_gemini_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
AVEAI_API_KEY=your_aveai_api_key_here

# Analytics & Data APIs
NANSEN_API_KEY=your_nansen_api_key_here

# Discord Webhooks
DISCORD_WEBHOOK_AI_BULLETIN=your_discord_webhook_url_here
DISCORD_WEBHOOK_ARKHAM_TRANSACTIONS=your_discord_webhook_url_here
DISCORD_WEBHOOK_SOL_SWAP=your_discord_webhook_url_here
DISCORD_WEBHOOK_PERPS_SIGNAL=your_discord_webhook_url_here

# Discord Bot Configuration
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_GUILD_ID=your_discord_guild_id_here
DISCORD_VIP_ROLE_ID=your_discord_vip_role_id_here

# Treasury & Payments
TREASURY_WALLET_ADDRESS=your_solana_wallet_address_here

# Security
MASTER_ENCRYPTION_KEY=your_encryption_key_here

# Privy Authentication
PRIVY_APP_ID=your_privy_app_id_here
PRIVY_APP_SECRET=your_privy_app_secret_here

# GitHub
GITHUB_TOKEN=your_github_token_here

# Scraper Configurations
KOLSCAN_COOKIE=your_kolscan_cookie_here
AVE_X_AUTH=your_ave_x_auth_here
PUMP_COOKIE=your_pump_cookie_here

# Notification Settings
MIN_USD_THRESHOLD=500.0

# API Server Port (Railway will set this automatically)
PORT=3000
