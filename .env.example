# ============================================================
# Minerva AI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Agent Mode ---
# Options: "paper" (simulated trading) or "live" (real trading)
AGENT_MODE=paper

# Agent loop interval in seconds (how often the brain runs)
AGENT_LOOP_INTERVAL=60

# Comma-separated trading pairs
TRADING_PAIRS=BTC/USDT,ETH/USDT

# --- Exchange API Keys ---
# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit (optional)
BYBIT_API_KEY=
BYBIT_API_SECRET=

# OKX (optional)
OKX_API_KEY=
OKX_API_SECRET=
OKX_PASSPHRASE=

# Primary exchange: binance, bybit, or okx
PRIMARY_EXCHANGE=binance
EXCHANGE_SANDBOX=false

# --- LLM API ---
# Groq (Llama 3 70B) — fast inference
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI (GPT-4o) — complex reasoning (fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# Override this for 9router (e.g. http://localhost:20128/v1)
OPENAI_BASE_URL=https://api.openai.com/v1

# Primary LLM provider: groq or openai
LLM_PROVIDER=groq

# LLM call timeout in seconds
LLM_TIMEOUT=5

# --- Redis ---
# Use redis:// for local, rediss:// for TLS (Upstash)
REDIS_URL=redis://redis:6379/0

# --- Supabase ---
SUPABASE_URL=
SUPABASE_KEY=

# --- Pinecone (Vector DB) ---
PINECONE_API_KEY=
PINECONE_INDEX_NAME=minerva-memory

# --- On-Chain Data (optional) ---
ALCHEMY_WS_URL=
WHALE_TRANSFER_THRESHOLD_ETH=100

# --- News & Social (optional) ---
CRYPTOPANIC_API_KEY=
TWITTER_BEARER_TOKEN=

# --- Telegram Notifications ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Monitoring (optional) ---
PROMETHEUS_PUSHGATEWAY_URL=
LOGTAIL_TOKEN=

# --- Risk Management ---
MAX_POSITION_SIZE_USD=1000
MAX_TOTAL_EXPOSURE_USD=5000
MAX_DRAWDOWN_PERCENT=10
DAILY_LOSS_LIMIT_USD=500

# --- Jarvis HUD ---
JARVIS_HUD_ENABLED=true
JARVIS_WS_PORT=8081
JARVIS_WS_HOST=127.0.0.1
JARVIS_WS_AUTH_TOKEN=
# Leave empty to use built-in Minerva chat. Set to Hermes API URL when available.
HERMES_API_URL=

# --- Logging ---
LOG_LEVEL=INFO
